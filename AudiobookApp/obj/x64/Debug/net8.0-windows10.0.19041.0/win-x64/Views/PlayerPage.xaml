<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AudiobookApp.Views.PlayerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AudiobookApp.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    >

    <Page.Resources>
        <local:SecondsToTimeConverter x:Key="SecondsToTimeConverter" />
    </Page.Resources>

    <StackPanel
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Spacing="10">

        <Border Width="180"
        Height="180"
        CornerRadius="8"
        HorizontalAlignment="Center"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1">
            <Grid>
                <Image x:ConnectionId='13' x:Name="CoverImage"
               Stretch="UniformToFill"/>
                <FontIcon x:ConnectionId='14' x:Name="CoverPlaceholder"
                  Glyph="&#xE8D6;"
                  FontSize="48"
                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <TextBlock x:ConnectionId='2'
            x:Name="TitleText"
            FontSize="18"
            FontWeight="SemiBold"
            TextAlignment="Center"
            TextWrapping="WrapWholeWords"
            HorizontalAlignment="Center"/>

        <TextBlock x:ConnectionId='3'
            x:Name="AuthorText"
            FontSize="14"
            Opacity="0.7"
            TextAlignment="Center"
            TextWrapping="WrapWholeWords"
            HorizontalAlignment="Center"/>

        <StackPanel
            Orientation="Horizontal"
            HorizontalAlignment="Center"
            Spacing="20">

            <Button x:ConnectionId='9' x:Name="PreviousButton">
                <SymbolIcon Symbol="Previous"/>
            </Button>

            <Button x:ConnectionId='10'
                x:Name="PlayPauseButton"
                Width="64"
                Height="64"
                                             >

                <SymbolIcon x:ConnectionId='12'
                    x:Name="PlayPauseIcon"
                    Symbol="Play"/>
            </Button>

            <Button x:ConnectionId='11' x:Name="NextButton">
                <SymbolIcon Symbol="Next"/>
            </Button>

        </StackPanel>

        <StackPanel
            Width="500"
            HorizontalAlignment="Center"
            Spacing="8">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:ConnectionId='6'
            x:Name="CurrentTimeText"
            VerticalAlignment="Center"
            Text="00:00:00"/>

                <Slider x:ConnectionId='7'
                x:Name="ProgressSlider"
                Grid.Column="1"
                Margin="10,0"
                Minimum="0"
                Maximum="100"
                StepFrequency="1"

                                                          

                                                              
                                                                
                                                                   

                ThumbToolTipValueConverter="{StaticResource SecondsToTimeConverter}"/>
                

                <TextBlock x:ConnectionId='8'
            x:Name="TotalTimeText"
            Grid.Column="2"
            VerticalAlignment="Center"
            Text="00:00:00"/>
            </Grid>

        </StackPanel>

        <StackPanel
    Orientation="Horizontal"
    HorizontalAlignment="Center"
    Spacing="10">

            <TextBlock
        Text="Speed"
        VerticalAlignment="Center"/>

            <ComboBox x:ConnectionId='5'
        x:Name="PlaybackSpeedBox"
        Width="90"
                                                            >

                <ComboBoxItem Content="0.5x"/>
                <ComboBoxItem Content="0.75x"/>
                <ComboBoxItem Content="1.0x"/>
                <ComboBoxItem Content="1.25x"/>
                <ComboBoxItem Content="1.5x"/>
                <ComboBoxItem Content="1.75x"/>
                <ComboBoxItem Content="2.0x"/>
                <ComboBoxItem Content="2.5x"/>
                <ComboBoxItem Content="3.0x"/>
                <ComboBoxItem Content="3.5x"/>
                <ComboBoxItem Content="4.0x"/>

            </ComboBox>

        </StackPanel>

        <MediaPlayerElement x:ConnectionId='4'
            x:Name="AudioPlayer"
            AreTransportControlsEnabled="False"
            AutoPlay="False"
            Visibility="Collapsed"/>

    </StackPanel>
</Page>

