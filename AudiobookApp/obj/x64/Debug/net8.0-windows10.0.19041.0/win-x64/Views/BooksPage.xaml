<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AudiobookApp.Views.BooksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button x:ConnectionId='2' x:Name="ImportButton"
            Content="Import Audiobook"
            Margin="10"
                                      />

        <ListView x:ConnectionId='3' x:Name="BooksList"
              Grid.Row="1">

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="8">

                        <Grid.ContextFlyout>
                            <MenuFlyout>

                                <MenuFlyoutItem x:ConnectionId='5' Text="Remove"
                                                            />

                            </MenuFlyout>
                        </Grid.ContextFlyout>

                        <StackPanel>
                            <TextBlock Text="{Binding Title}" FontSize="16"/>
                            <TextBlock Text="{Binding Author}" Opacity="0.7"/>
                        </StackPanel>

                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>

        </ListView>

    </Grid>

</Page>

