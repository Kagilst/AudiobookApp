<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AudiobookApp.Views.ImportBookDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AudiobookApp.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <Grid MinHeight="400">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="16"
                        Padding="40"
                        MaxWidth="360">

                <TextBlock Text="Import Audiobook"
                           FontSize="24"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>

                <Border Width="180"
                        Height="180"
                        CornerRadius="8"
                        HorizontalAlignment="Center"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Image x:ConnectionId='6' x:Name="CoverImage"
                               Stretch="UniformToFill"/>
                        <FontIcon x:ConnectionId='7' x:Name="CoverPlaceholder"
                                  Glyph="&#xE8D6;"
                                  FontSize="48"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <TextBlock x:ConnectionId='2' x:Name="TitleText"
                           FontSize="18"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           TextWrapping="WrapWholeWords"
                           HorizontalAlignment="Center"/>

                <TextBlock x:ConnectionId='3' x:Name="AuthorText"
                           FontSize="14"
                           Opacity="0.7"
                           TextAlignment="Center"
                           TextWrapping="WrapWholeWords"
                           HorizontalAlignment="Center"/>

                <StackPanel Spacing="8"
                            Width="280"
                            HorizontalAlignment="Center">
                    <TextBlock Text="Category"
                               FontWeight="SemiBold"/>
                    <ComboBox x:ConnectionId='5' x:Name="CategoryCombo"
                              HorizontalAlignment="Stretch"/>
                </StackPanel>

                <Button x:ConnectionId='4' Content="Import"
                        Style="{StaticResource AccentButtonStyle}"
                                            
                        HorizontalAlignment="Stretch"
                        MinWidth="280"/>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>

