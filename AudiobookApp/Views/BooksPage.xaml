<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AudiobookApp.Views.BooksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Page.Resources>
        <DataTemplate x:Key="BookListTemplate">
            <Grid Padding="10">
                <Grid.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="Remove"
                                        Click="RemoveBook_Click"/>
                    </MenuFlyout>
                </Grid.ContextFlyout>

                <Grid ColumnDefinitions="56,*"
                      ColumnSpacing="14"
                      MinHeight="64">
                    <Border Width="48"
                            Height="48"
                            CornerRadius="4"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <Grid>
                            <FontIcon Glyph="&#xE8D6;"
                                      FontSize="20"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            <Image Source="{Binding CoverImage}"
                                   Stretch="UniformToFill"/>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                Spacing="2">
                        <TextBlock Text="{Binding Title}"
                                   FontSize="16"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding Author}"
                                   Opacity="0.7"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="BookIconTemplate">
            <Grid Width="168"
                  Padding="8">
                <Grid.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="Remove"
                                        Click="RemoveBook_Click"/>
                    </MenuFlyout>
                </Grid.ContextFlyout>

                <StackPanel Spacing="8">
                    <Border Width="140"
                            Height="140"
                            CornerRadius="8"
                            HorizontalAlignment="Center"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <Grid>
                            <FontIcon Glyph="&#xE8D6;"
                                      FontSize="38"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            <Image Source="{Binding CoverImage}"
                                   Stretch="UniformToFill"/>
                        </Grid>
                    </Border>

                    <StackPanel Spacing="2">
                        <TextBlock Text="{Binding Title}"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center"
                                   TextWrapping="WrapWholeWords"
                                   MaxLines="1"/>
                        <TextBlock Text="{Binding Author}"
                                   Opacity="0.7"
                                   TextAlignment="Center"
                                   TextWrapping="WrapWholeWords"
                                   MaxLines="2"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid Padding="16"
          RowDefinitions="Auto,*"
          RowSpacing="12">

        <Grid ColumnDefinitions="Auto,*"
              ColumnSpacing="12">
            <Button x:Name="ImportButton"
                    Click="ImportButton_Click">
                <StackPanel Orientation="Horizontal"
                            Spacing="8">
                    <SymbolIcon Symbol="Add"/>
                    <TextBlock Text="Import Audiobook" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8"
                        HorizontalAlignment="Right">
                <ToggleButton x:Name="ListViewButton"
                              Click="ListViewButton_Click"
                              IsChecked="True">
                    <StackPanel Orientation="Horizontal"
                                Spacing="8">
                        <FontIcon Glyph="&#xE8FD;"
                                  FontSize="14"/>
                        <TextBlock Text="List"/>
                    </StackPanel>
                </ToggleButton>

                <ToggleButton x:Name="IconViewButton"
                              Click="IconViewButton_Click">
                    <StackPanel Orientation="Horizontal"
                                Spacing="8">
                        <FontIcon Glyph="&#xE8A9;"
                                  FontSize="14"/>
                        <TextBlock Text="Large icons"/>
                    </StackPanel>
                </ToggleButton>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <ListView x:Name="BooksList"
                      ItemTemplate="{StaticResource BookListTemplate}"
                      IsItemClickEnabled="True"
                      ItemClick="BooksList_ItemClick"/>

            <GridView x:Name="BooksGrid"
                      ItemTemplate="{StaticResource BookIconTemplate}"
                      Visibility="Collapsed"
                      SelectionMode="Single"
                      IsItemClickEnabled="True"
                      ItemClick="BooksGrid_ItemClick">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal"
                                       MaximumRowsOrColumns="0"/>
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
            </GridView>
        </Grid>
    </Grid>
</Page>
